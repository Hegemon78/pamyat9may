---
/**
 * Preview section of the Memory Wall on the landing page.
 * Shows sample stories and links to full wall.
 *
 * TODO: Fetch real stories from bot API instead of hardcoded samples.
 * TODO: Add masonry grid layout for varied card heights.
 * TODO: Add photo thumbnails on cards when available.
 */
const sampleStories = [
  {
    heroName: 'Иван Петрович Сидоров',
    years: '1920–1985',
    text: 'Мой дедушка прошёл всю войну от Москвы до Берлина. Командир разведвзвода, дважды ранен. Награждён орденом Красной Звезды за операцию под Курском.',
    author: 'Мария С.'
  },
  {
    heroName: 'Николай Фёдорович Волков',
    years: '1918–1943',
    text: 'Капитан, лётчик-истребитель. 186 боевых вылетов, 12 сбитых самолётов противника. Погиб в бою на Курской дуге. Герой Советского Союза посмертно.',
    author: 'Алексей В.'
  },
  {
    heroName: 'Анна Степановна Белова',
    years: '1925–2015',
    text: 'С 16 лет работала на оборонном заводе, точила снаряды по 12 часов. Медаль «За доблестный труд». До последних дней вспоминала подруг по цеху.',
    author: 'Елена Б.'
  },
  {
    heroName: 'Мария Ивановна Козлова',
    years: '1923–2010',
    text: 'Фронтовая медсестра, старшина медицинской службы. Вынесла с поля боя более 200 раненых. Медаль «За отвагу». Всю жизнь проработала врачом.',
    author: 'Дмитрий К.'
  }
];
---

<section class="py-16 md:py-24 relative overflow-hidden">
  <div class="absolute inset-0">
    <img src="/pamyat9may/images/hero-bg.png" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-bg-900/94"></div>
  </div>
  <div class="relative">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-14 reveal">
      <span class="text-gold-500 text-xs font-sans font-bold tracking-[0.2em] uppercase mb-3 block">Стена памяти</span>
      <h2 class="text-3xl md:text-5xl text-paper-50 mb-4">Истории наших семей</h2>
      <p class="text-paper-300/50 font-sans max-w-xl mx-auto">
        Каждая история — живая память. Расскажите о своём герое, чтобы его подвиг не был забыт.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 stagger-children">
      {sampleStories.map((story, i) => (
        <div class="reveal glass rounded-xl p-6 hover:border-gold-400/20 transition-all" style={`transition-delay: ${i * 80}ms`}>
          <div class="flex items-start gap-4">
            <!-- Medal icon placeholder -->
            <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg viewBox="0 0 24 24" class="w-5 h-5 text-gold-400" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-paper-50 font-bold text-base">{story.heroName}</h3>
              <span class="font-date text-gold-600 text-xs">{story.years}</span>
              <p class="text-paper-300/50 text-sm font-sans leading-relaxed mt-2">{story.text}</p>
              <p class="text-paper-300/30 text-xs font-sans mt-3">— {story.author}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10 reveal">
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/wall`} class="btn-outline">
        Все истории на Стене памяти
      </a>
      <span class="mx-4 text-paper-300/20">|</span>
      <a href="#stories-form" class="btn-gold">
        Рассказать историю
      </a>
    </div>
  </div>
  </div>
</section>
