---
/**
 * Gallery section — "before/after" showcase of AI photo restoration.
 *
 * 12 veteran cards with hover crossfade (black-and-white → colorized).
 * Click opens modal with short biography.
 *
 * TODO: Заменить picsum placeholders на реальные фото через nanobanana (место под реальные фото).
 * TODO: улучшить hover-анимацию crossfade (плавнее, с эффектом "проявления")
 * TODO: добавить scroll-reveal анимацию для карточек (сейчас только базовая .reveal)
 * TODO: pixel-perfect мобильная адаптация (375px, 414px, 768px)
 * TODO: lazy-load изображения + blur-up placeholder
 */

// Моковые данные: 12 ветеранов. Placeholder-фото через picsum (позже заменим на реальные).
const galleryItems = [
  {
