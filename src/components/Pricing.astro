---
/**
 * Pricing section — two-block layout:
 *
 * 1) Оживление фото — 4 тарифа с объёмной скидкой (1 / 5 / 10 / безлимит)
 * 2) Биография к фото — 4 варианта (бесплатно / +200₽ / +500₽ / TBD древо)
 *
 * TODO: pixel-perfect мобильная адаптация для обоих блоков
 * TODO: анимировать hover на карточках (подъём, свечение)
 * TODO: добавить scroll-reveal с плавным fade-in
 * TODO: синхронизировать выбранный тариф с OrderForm (passing state via query param)
 */

// Блок 1: Оживление фото
const revivalTiers = [
  {
    id: 'one',
    name: '1 фото',
    price: 299,
    oldPrice: null,
    perPhoto: 299,
    discount: null,
    tag: null,
    features: [
      'AI-реставрация + колоризация',
      'Художественное восстановление',
      'Скачивание без водяного знака',
      'Результат за 5-10 минут',
    ],
    cta: 'Оживить 1 фото',
    highlighted: false,
  },
  {
    id: 'five',
    name: '5 фото',
    price: 1290,
    oldPrice: 1495,
    perPhoto: 258,
    discount: '-13%',
    tag: 'Хит',
    features: [
      'Всё из тарифа «1 фото»',
      'Экономия 205₽',
      'Приоритетная обработка',
      'Хранение в личном кабинете',
    ],
    cta: 'Пакет 5 фото',
    highlighted: true,
  },
  {
    id: 'ten',
    name: '10 фото',
    price: 2390,
    oldPrice: 2990,
    perPhoto: 239,
    discount: '-20%',
    tag: 'Выгодно',
    features: [
      'Всё из тарифа «5 фото»',
      'Экономия 600₽',
      'Видео-портрет (2 шт. в подарок)',
      'Поддержка в Telegram',
    ],
    cta: 'Пакет 10 фото',
    highlighted: false,
  },
  {
    id: 'family',
    name: 'Безлимит на семью',
    price: 4990,
    oldPrice: null,
    perPhoto: null,
    discount: null,
    tag: 'Максимум',
    features: [
      'Сколько угодно фото за год',
      'Видео-портреты без ограничений',
      'Полный доступ к личному кабинету',
      'Приватный режим для семейного архива',
    ],
    cta: 'Оформить безлимит',
    highlighted: false,
  },
];

// Блок 2: Биография к фото
const biographyOptions = [
  {
    id: 'bio_free',
    name: 'Краткая',
    limit: 'до 500 символов',
    price: 0,
    priceLabel: 'Бесплатно',
    description: 'Имя, годы жизни, короткая заметка — всё, что поместится на мемориальной карточке.',
    tag: null,
  },
  {
    id: 'bio_200',
    name: 'Расширенная',
    limit: 'до 2 000 символов',
    price: 200,
    priceLabel: '+200 ₽',
    description: 'Боевой путь, ключевые события, цитаты из писем — полноценная страница памяти.',
    tag: 'Популярное',
  },
  {
    id: 'bio_500',
    name: 'Полная',
    limit: 'до 5 000 символов',
    price: 500,
    priceLabel: '+500 ₽',
    description: 'Подробный рассказ с деталями, воспоминаниями родственников, историческим контекстом.',
    tag: null,
  },
  {
    id: 'bio_tree',
    name: 'Генеалогическое древо',
    limit: 'Несколько поколений',
    price: null,
    priceLabel: 'Скоро',
    description: 'Интерактивное древо семьи с оживлёнными портретами предков. В разработке.',
    tag: 'В планах',
  },
];
---

<section class="py-16 md:py-24 bg-bg-800" id="pricing">
  <div class="max-w-6xl mx-auto px-4">

    <!-- ============== BLOCK 1: Revival tiers ============== -->
    <div class="text-center mb-12 reveal">
      <span class="text-gold-500 text-xs font-sans font-bold tracking-[0.2em] uppercase mb-3 block">
        Тарифы
      </span>
      <h2 class="text-3xl md:text-5xl text-paper-50 mb-4">
        Оживление фото
      </h2>
      <p class="text-paper-300/50 font-sans max-w-xl mx-auto">
        Чем больше фото в пакете — тем ниже цена за каждое. Храните всю семейную историю в одном месте.
      </p>
    </div>

    <!-- Revival tiers grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 stagger-children mb-20">
      {revivalTiers.map((tier, i) => (
        <div class="reveal flex flex-col" style={`transition-delay: ${i * 80}ms`}>
          <div
            class={[
              "flex flex-col h-full rounded-2xl p-6 transition-all duration-300 group relative",
              "backdrop-blur-xl",
              tier.highlighted
                ? "border-2 border-gold-400/50 hover:border-gold-400/70"
                : "glass hover:border-gold-400/30",
            ].join(" ")}
            style={tier.highlighted
              ? "background: rgba(218, 165, 32, 0.1); backdrop-filter: blur(16px);"
              : undefined}
          >
            {/* Tag */}
            {tier.tag && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full text-[0.625rem] font-sans font-bold uppercase tracking-wider"
                style="background: linear-gradient(135deg, #DAA520, #B8860B); color: #0D0B09; box-shadow: 0 4px 12px rgba(218,165,32,0.35);">
                {tier.tag}
              </div>
            )}

            {/* Header */}
            <div class="mb-4 mt-2">
              <span class="text-paper-300/60 font-sans text-xs font-bold uppercase tracking-widest block mb-2">
                {tier.name}
              </span>
            </div>

            {/* Price block */}
            <div class="mb-6">
              <div class="flex items-baseline gap-2 flex-wrap">
                {tier.oldPrice && (
                  <span class="text-paper-300/40 text-base font-sans line-through">
                    {tier.oldPrice}₽
                  </span>
                )}
                <span class="text-4xl md:text-5xl font-bold font-serif text-gold-400">
                  {tier.price.toLocaleString('ru-RU')}
                </span>
                <span class="text-paper-300/50 font-sans text-sm">₽</span>
              </div>
              {tier.perPhoto && tier.id !== 'one' && (
                <div class="text-paper-300/50 text-xs font-sans mt-1.5">
                  {tier.perPhoto}₽ за фото
                </div>
              )}
              {tier.discount && (
                <span class="inline-block mt-2 text-[0.625rem] font-sans font-bold uppercase tracking-wider px-2 py-0.5 rounded"
                  style="background: rgba(220, 20, 60, 0.15); color: #DC143C; border: 1px solid rgba(220, 20, 60, 0.3);">
                  Скидка {tier.discount}
                </span>
              )}
            </div>

            {/* Divider */}
            <div class="h-px bg-gold-400/10 mb-5"></div>

            {/* Features */}
            <ul class="flex flex-col gap-3 mb-8 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2.5">
                  <svg
                    viewBox="0 0 24 24"
                    class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  <span class="text-paper-300/70 font-sans text-sm leading-snug">
                    {feature}
                  </span>
                </li>
              ))}
            </ul>

            {/* CTA */}
            <a
              href={`#order-form?tier=${tier.id}`}
              class={[
                "block text-center font-sans font-bold text-sm py-3 px-5 rounded-lg transition-all duration-200",
                tier.highlighted ? "" : "hover:bg-gold-400/10",
              ].join(" ")}
              style={tier.highlighted
                ? "background: linear-gradient(135deg, #DAA520, #B8860B); color: #0D0B09; text-decoration: none;"
                : "border: 1px solid var(--color-gold-500); color: var(--color-gold-400); text-decoration: none; background: transparent;"}
            >
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- ============== BLOCK 2: Biography options ============== -->
    <div class="text-center mb-12 reveal">
      <span class="text-gold-500 text-xs font-sans font-bold tracking-[0.2em] uppercase mb-3 block">
        Доп. опция
      </span>
      <h2 class="text-3xl md:text-5xl text-paper-50 mb-4">
        Биография к фото
      </h2>
      <p class="text-paper-300/50 font-sans max-w-xl mx-auto">
        Добавьте историю героя к оживлённой фотографии. Чем подробнее — тем живее память.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 stagger-children">
      {biographyOptions.map((opt, i) => (
        <div class="reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class={[
            "h-full rounded-xl p-5 transition-all duration-300 relative",
            "glass hover:border-gold-400/30",
            opt.tag === 'В планах' ? 'opacity-70' : ''
          ].join(' ')}>
            {opt.tag && (
              <div class="absolute top-3 right-3 text-[0.5625rem] font-sans font-bold uppercase tracking-wider px-2 py-0.5 rounded-full"
                style={opt.tag === 'В планах'
                  ? "background: rgba(107, 142, 35, 0.15); color: #6B8E23; border: 1px solid rgba(107, 142, 35, 0.3);"
                  : "background: rgba(218, 165, 32, 0.15); color: #DAA520; border: 1px solid rgba(218, 165, 32, 0.3);"}>
                {opt.tag}
              </div>
            )}

            <h3 class="text-paper-50 font-bold text-base mb-1">{opt.name}</h3>
            <div class="text-paper-300/50 text-xs font-sans mb-4">{opt.limit}</div>

            <div class="mb-4">
              {opt.price === 0 ? (
                <span class="text-2xl font-bold font-serif text-olive-500">{opt.priceLabel}</span>
              ) : opt.price === null ? (
                <span class="text-2xl font-bold font-serif text-paper-300/60">{opt.priceLabel}</span>
              ) : (
                <div class="flex items-baseline gap-1">
                  <span class="text-2xl font-bold font-serif text-gold-400">{opt.priceLabel}</span>
                </div>
              )}
            </div>

            <p class="text-paper-300/60 text-xs font-sans leading-relaxed">{opt.description}</p>

            {/* TODO: Phase 2 — интеграция с генеалогическим древом */}
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <div class="text-center mt-12 reveal">
      <p class="text-paper-300/40 text-xs font-sans max-w-lg mx-auto">
        Оплата по СБП, Apple Pay, Google Pay. Чек отправим на email. Все данные хранятся в зашифрованном виде.
      </p>
    </div>
  </div>
</section>
