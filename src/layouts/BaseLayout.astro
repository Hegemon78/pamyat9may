---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Оживите фотографию ветерана, сохраните историю на Стене памяти, проверьте знания о войне.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Память 9 Мая`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=PT+Sans:wght@400;700&family=PT+Serif:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title} | Память 9 Мая</title>
  </head>
  <body class="min-h-screen flex flex-col bg-bg-900">
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
      <div class="george-stripe"></div>
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between font-sans">
        <a href={`${base}/`} class="flex items-center gap-2 group">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-gold-400 group-hover:text-gold-300 transition-colors" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-gold-400 font-bold text-sm tracking-wider uppercase">Память 9 Мая</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-xs text-paper-300/60">
          <a href={`${base}/#revive`} class="hover:text-paper-100 transition-colors">Оживи фото</a>
          <a href={`${base}/#gallery`} class="hover:text-paper-100 transition-colors">Галерея</a>
          <a href={`${base}/wall`} class="hover:text-paper-100 transition-colors">Стена памяти</a>
          <a href={`${base}/#quiz`} class="hover:text-paper-100 transition-colors">Викторина</a>
          <a href={`${base}/#timeline`} class="hover:text-paper-100 transition-colors">Хронология</a>
        </div>
        <!-- TODO: mobile hamburger menu for frontend developer -->
        <div class="flex items-center gap-2 md:gap-3">
          <!-- Login button — opens "coming soon" modal -->
          <button
            type="button"
            id="open-login-modal"
            class="text-[11px] md:text-xs font-sans font-bold uppercase tracking-wider px-3 md:px-4 py-2 rounded-lg border border-gold-400/30 text-gold-400 hover:bg-gold-400/10 hover:border-gold-400/50 transition-all"
            aria-label="Войти в личный кабинет"
          >
            <span class="flex items-center gap-1.5">
              <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
              </svg>
              <span class="hidden sm:inline">Войти</span>
            </span>
          </button>
          <a href="#revive" class="btn-gold text-xs py-2 px-3 md:px-4">
            Оживить фото
          </a>
        </div>
      </nav>
    </header>

    <!-- ============== LOGIN MODAL (заглушка) ============== -->
    <div
      id="login-modal"
      class="fixed inset-0 z-[200] hidden items-center justify-center p-4"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-labelledby="login-modal-title"
    >
      <div class="absolute inset-0 bg-bg-900/90 backdrop-blur-sm" data-login-close></div>

      <div class="relative max-w-md w-full glass rounded-2xl p-6 md:p-8 max-h-[90vh] overflow-y-auto" style="background: rgba(20, 18, 16, 0.98); border: 1px solid rgba(218, 165, 32, 0.25);">
        <button
          type="button"
          class="absolute top-3 right-3 w-9 h-9 rounded-full flex items-center justify-center text-paper-300/60 hover:text-gold-400 hover:bg-gold-400/10 transition-colors"
          data-login-close
          aria-label="Закрыть"
        >
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>

        <!-- Icon -->
        <div class="w-16 h-16 rounded-full mx-auto mb-5 bg-gradient-to-br from-gold-400/20 to-gold-600/10 border border-gold-400/30 flex items-center justify-center">
          <svg viewBox="0 0 24 24" class="w-8 h-8 text-gold-400" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>

        <h3 id="login-modal-title" class="text-paper-50 text-xl md:text-2xl font-bold text-center mb-2">
          Личный кабинет скоро
        </h3>
        <p class="text-paper-300/60 font-sans text-sm text-center mb-6">
          Мы готовим приватное пространство для ваших семейных историй.
        </p>

        <div class="h-px bg-gold-400/10 mb-6"></div>

        <p class="text-paper-300/70 text-xs font-sans uppercase tracking-wider font-bold mb-3">
          Что будет доступно
        </p>

        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            <span class="text-paper-300/70 font-sans text-sm">Сохранение всех оживлённых фото в одном месте</span>
          </li>
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            <span class="text-paper-300/70 font-sans text-sm">Приватный / публичный режим истории героя</span>
          </li>
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            <span class="text-paper-300/70 font-sans text-sm">Скачивание в высоком разрешении (до 4K)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg viewBox="0 0 24 24" class="w-4 h-4 mt-0.5 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            <span class="text-paper-300/70 font-sans text-sm">История заказов и семейных материалов</span>
          </li>
        </ul>

        <div class="h-px bg-gold-400/10 mb-5"></div>

        <p class="text-paper-200/70 text-xs font-sans text-center mb-3">
          Хотите узнать первым о запуске?
        </p>

        <!-- TODO: подключить реальный email-subscribe endpoint или Telegram Login Widget для auth -->
        <form id="notify-form" class="flex flex-col sm:flex-row gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="ваш.email@example.com"
            class="flex-1 px-3 py-2 rounded-lg bg-bg-900/60 border border-gold-400/20 text-paper-100 text-sm font-sans placeholder:text-paper-300/30 focus:outline-none focus:border-gold-400/50 transition-colors"
            aria-label="Email"
            required
          />
          <button
            type="submit"
            class="btn-gold text-xs px-4 py-2"
            id="notify-submit-btn"
          >
            Уведомить
          </button>
        </form>

        <p class="text-paper-300/30 text-[11px] font-sans text-center mt-4">
          Никакого спама. Одно письмо — когда кабинет откроется.
        </p>

        <!-- TODO: подключить Telegram Login Widget для auth через TG -->
        <!-- TODO: заменить fake submit на реальный API (POST /api/notify-subscribe) -->
      </div>
    </div>

    <main class="flex-1 pt-12">
      <slot />
    </main>

    <!-- Footer -->
    <div class="george-stripe"></div>
    <footer class="bg-navy-900 text-paper-300/70 py-10 mt-auto">
      <div class="max-w-5xl mx-auto px-4 font-sans text-center">
        <div class="flex items-center justify-center gap-2 mb-4">
          <svg viewBox="0 0 24 24" class="w-4 h-4 text-gold-500" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-gold-400 font-bold text-xs tracking-wider uppercase">Память 9 Мая</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs text-paper-300/50 mb-6">
          <a href={`${base}/`} class="hover:text-paper-100 transition-colors">Главная</a>
          <a href={`${base}/wall`} class="hover:text-paper-100 transition-colors">Стена памяти</a>
          <a href="https://t.me/pamyat9may_bot" class="hover:text-paper-100 transition-colors">Telegram-бот</a>
        </nav>
        <p class="text-[10px] text-paper-300/30 max-w-md mx-auto mb-3">
          AI-обработка фотографий создаёт художественную интерпретацию, а не документальное восстановление.
        </p>
        <p class="text-paper-300/40 text-xs">&copy; {new Date().getFullYear()} &bull; Помним. Гордимся. Чтим.</p>
      </div>
    </footer>

    <script>
      // Header background on scroll
      const header = document.getElementById('site-header');
      if (header) {
        window.addEventListener('scroll', () => {
          header.style.background = window.scrollY > 50
            ? 'rgba(13, 11, 9, 0.95)'
            : 'transparent';
          header.style.backdropFilter = window.scrollY > 50 ? 'blur(12px)' : 'none';
        }, { passive: true });
      }

      // Scroll reveal observer
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-left').forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${i * 60}ms`;
        revealObserver.observe(el);
      });

      // Stagger children
      document.querySelectorAll('.stagger-children').forEach(parent => {
        Array.from(parent.children).forEach((child, i) => {
          (child as HTMLElement).style.setProperty('--i', String(i));
        });
      });

      // Login modal (заглушка — "Личный кабинет скоро")
      (() => {
        const loginModal = document.getElementById('login-modal');
        const openBtn = document.getElementById('open-login-modal');
        if (!loginModal || !openBtn) return;

        const open = () => {
          loginModal.classList.remove('hidden');
          loginModal.classList.add('flex');
          loginModal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        };
        const close = () => {
          loginModal.classList.add('hidden');
          loginModal.classList.remove('flex');
          loginModal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        };

        openBtn.addEventListener('click', open);
        loginModal.querySelectorAll('[data-login-close]').forEach((el) => {
          el.addEventListener('click', close);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !loginModal.classList.contains('hidden')) close();
        });

        // Fake email subscribe — just show a thank-you message
        const form = document.getElementById('notify-form') as HTMLFormElement | null;
        const submitBtn = document.getElementById('notify-submit-btn') as HTMLButtonElement | null;
        if (form && submitBtn) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
            if (!input || !input.value.trim()) return;
            submitBtn.textContent = 'Готово ✓';
            submitBtn.style.background = 'linear-gradient(135deg, #6B8E23, #556B2F)';
            input.disabled = true;
            // TODO: отправка на реальный endpoint (POST /api/notify-subscribe)
          });
        }
      })();
    </script>
  </body>
</html>
